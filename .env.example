# Network Automation System - 环境变量配置
# 复制此文件为 .env 并填入实际值
# ⚠️ 不要将 .env 提交到版本控制！

# 数据库
DATABASE_URL=sqlite:///data/app.db

# JWT 认证（生产环境必须修改）
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRE_MINUTES=1440

# 加密密钥（用于凭证加密存储）
ENCRYPTION_KEY=change-me-in-production-32-characters!!

# 告警通知
ALERTS_ENABLED=false

# 企业微信 Webhook（可选）
WECHAT_WORK_WEBHOOK_URL=

# 钉钉 Webhook（可选）
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=

# 邮件告警（可选）
SMTP_HOST=smtp.company.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDR=
SMTP_RECIPIENTS=admin@company.com

# CORS（生产环境必须改为具体域名，逗号分隔）
ALLOWED_ORIGINS=*

# 限流
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# Redis 缓存（可选）
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_DEFAULT_TTL=60

# 存储路径
BACKUP_DIR=./backups
PHOTO_DIR=./assets/devices
LOG_DIR=./logs
MAX_BACKUPS_PER_DEVICE=30
BACKUP_RETENTION_DAYS=365
