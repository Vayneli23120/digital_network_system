# ============================================
# Network Automation System 环境变量配置
# ============================================
# 复制此文件为 .env 并修改实际值
# ⚠️ 不要将 .env 提交到版本控制！

# === 数据库 ===
# SQLite (开发):
DATABASE_URL=sqlite+aiosqlite:///data/nas.db
# PostgreSQL (生产):
# DB_USER=nasuser
# DB_PASSWORD=change_me_strong_password_here
# DATABASE_URL=postgresql+asyncpg://nasuser:change_me_strong_password_here@localhost:5432/nas

# === Redis ===
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_DEFAULT_TTL=60

# === Celery 任务队列 ===
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# === JWT 认证 ===
# 生产环境必须修改！生成强随机密钥:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production-use-a-long-random-string-min-32-chars
JWT_EXPIRE_MINUTES=1440
AUTH_ENABLED=false

# === 加密密钥 ===
# 用于凭证加密存储，必须 32 字符
ENCRYPTION_KEY=change-me-in-production-32-characters!!

# === CORS ===
# 生产环境必须改为具体域名，逗号分隔，禁止使用 *
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# === 限流 ===
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# === 告警通知 ===
ALERTS_ENABLED=false

# 企业微信 Webhook
WECHAT_WORK_WEBHOOK_URL=

# 钉钉 Webhook
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=

# 邮件告警
SMTP_HOST=smtp.company.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDR=
SMTP_RECIPIENTS=admin@company.com

# === AI 配置 ===
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
AI_DEFAULT_MODEL=gpt-4o-mini

# === 存储路径 ===
BACKUP_DIR=./backups
PHOTO_DIR=./assets/devices
LOG_DIR=./logs
MAX_BACKUPS_PER_DEVICE=30
BACKUP_RETENTION_DAYS=365