# Frontend environment variables
# Copy to .env.local for local development

# Backend API base URL (for dev server proxy)
VITE_API_URL=http://localhost:8000

# WebSocket backend URL (bypass vite ws proxy issues in dev mode)
# Set to ws://<backend-ip>:8000 when accessing frontend remotely
# Example: VITE_WS_URL=ws://192.168.4.37:8000
#VITE_WS_URL=ws://localhost:8000

# API base URL for production builds (relative or absolute)
VITE_API_BASE_URL=/api
